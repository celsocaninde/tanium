msgid "Tanium Configuration"
msgstr "Configuração Tanium"

msgid "Tanium Sync"
msgstr "Sincronização Tanium"

msgid "Tanium Cron"
msgstr "Cron Tanium"

msgid "Tanium"
msgstr "Tanium"

msgid "API & Sync Configuration"
msgstr "Configuração de API e Sincronização"

msgid "Tanium Cloud API URL"
msgstr "URL da API Tanium Cloud"

msgid "Base URL of your Tanium Cloud instance, without trailing slash."
msgstr "URL base da sua instância Tanium Cloud, sem barra final."

msgid "API Token"
msgstr "Token de API"

msgid "Leave blank to keep the existing token. Tokens are generated in Tanium → Administration → API Tokens."
msgstr "Deixe em branco para manter o token existente. Tokens são gerados em Tanium → Administração → Tokens de API."

msgid "Data to synchronize"
msgstr "Dados a sincronizar"

msgid "Endpoints / Computers"
msgstr "Endpoints / Computadores"

msgid "Hardware details (CPU, RAM, disk)"
msgstr "Detalhes de hardware (CPU, RAM, disco)"

msgid "Installed software inventory"
msgstr "Inventário de software instalado"

msgid "Vulnerabilities & Patches (requires Tanium Comply)"
msgstr "Vulnerabilidades e Patches (requer Tanium Comply)"

msgid "Scheduler"
msgstr "Agendador"

msgid "Cron frequency (hours)"
msgstr "Frequência do cron (horas)"

msgid "How often the automatic sync runs. Minimum 1 hour."
msgstr "Com que frequência a sincronização automática executa. Mínimo 1 hora."

msgid "Endpoint import limit per run"
msgstr "Limite de importação de endpoints por execução"

msgid "Max endpoints fetched per API page. Tanium REST API v2 max is 500."
msgstr "Máximo de endpoints buscados por página da API. O máximo da API REST v2 do Tanium é 500."

msgid "Last sync: %s — %d endpoints processed"
msgstr "Última sincronização: %s — %d endpoints processados"

msgid "Save configuration"
msgstr "Salvar configuração"

msgid "Test connection"
msgstr "Testar conexão"

msgid "Sync now"
msgstr "Sincronizar agora"

msgid "Tanium — Configuration"
msgstr "Tanium — Configuração"

msgid "Tanium — Synchronization"
msgstr "Tanium — Sincronização"

msgid "Endpoint Synchronization"
msgstr "Sincronização de Endpoints"

msgid "API URL"
msgstr "URL da API"

msgid "Not configured"
msgstr "Não configurado"

msgid "Last sync"
msgstr "Última sincronização"

msgid "Endpoints processed"
msgstr "Endpoints processados"

msgid "Cron frequency"
msgstr "Frequência do cron"

msgid "Run synchronization now"
msgstr "Executar sincronização agora"

msgid "Configure"
msgstr "Configurar"

msgid "Sync History"
msgstr "Histórico de Sincronização"

msgid "No sync runs recorded yet."
msgstr "Nenhuma execução de sincronização registrada ainda."

msgid "Started"
msgstr "Início"

msgid "Finished"
msgstr "Término"

msgid "Status"
msgstr "Status"

msgid "Total"
msgstr "Total"

msgid "Created"
msgstr "Criados"

msgid "Updated"
msgstr "Atualizados"

msgid "Errors"
msgstr "Erros"

msgid "Message"
msgstr "Mensagem"

msgid "Tanium configuration saved."
msgstr "Configuração Tanium salva."

msgid "Please enter the API URL and token before testing."
msgstr "Por favor, insira a URL da API e o token antes de testar."

msgid "Connection successful. %s endpoints found in Tanium."
msgstr "Conexão bem-sucedida. %s endpoints encontrados no Tanium."

msgid "Tanium API authentication failed. Check your API token."
msgstr "Autenticação da API Tanium falhou. Verifique seu token de API."

msgid "Tanium API access forbidden. The token may lack required permissions."
msgstr "Acesso à API Tanium proibido. O token pode não ter as permissões necessárias."

msgid "Tanium API returned HTTP %d for %s"
msgstr "A API Tanium retornou HTTP %d para %s"

msgid "Invalid JSON from Tanium API: %s"
msgstr "JSON inválido da API Tanium: %s"

msgid "cURL error: %s"
msgstr "Erro cURL: %s"

msgid "Unexpected API response structure."
msgstr "Estrutura de resposta da API inesperada."

msgid "Tanium plugin: API URL or token not configured. Skipping."
msgstr "Plugin Tanium: URL da API ou token não configurado. Pulando."

msgid "Tanium sync started…"
msgstr "Sincronização Tanium iniciada…"

msgid "Tanium sync finished — total: %d | created: %d | updated: %d | errors: %d"
msgstr "Sincronização Tanium concluída — total: %d | criados: %d | atualizados: %d | erros: %d"

msgid "Tanium sync complete — %d endpoints processed: %d created, %d updated, %d errors."
msgstr "Sincronização Tanium concluída — %d endpoints processados: %d criados, %d atualizados, %d erros."

msgid "Tanium — synchronize endpoints, software and hardware into GLPI assets."
msgstr "Tanium — sincronizar endpoints, software e hardware nos ativos do GLPI."

msgid "Hours between runs (overrides plugin setting)"
msgstr "Horas entre execuções (substitui a configuração do plugin)"

msgid "The PHP cURL extension is required by the Tanium plugin."
msgstr "A extensão PHP cURL é necessária pelo plugin Tanium."

msgid "The PHP JSON extension is required by the Tanium plugin."
msgstr "A extensão PHP JSON é necessária pelo plugin Tanium."
